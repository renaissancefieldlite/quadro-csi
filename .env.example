# Quadro environment template.
# Copy to .env locally. Do not commit real keys.

QUADRO_MODE=local
QUADRO_HOST=127.0.0.1
QUADRO_PORT=8867

# Band platform credentials open after Band account setup.
BAND_REST_URL=https://app.band.ai/
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
QUADRO_PUBLISH_TO_BAND=0
QUADRO_BAND_CHAT_ID=

# One Band remote-agent credential per Quadro role.
QUADRO_INTAKE_AGENT_ID=
QUADRO_INTAKE_API_KEY=
QUADRO_EVIDENCE_AGENT_ID=
QUADRO_EVIDENCE_API_KEY=
QUADRO_POLICY_AGENT_ID=
QUADRO_POLICY_API_KEY=
QUADRO_DECISION_AGENT_ID=
QUADRO_DECISION_API_KEY=

# Optional model provider key for later LLM-powered agent turns.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AIMLAPI_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=
AIMLAPI_MAX_TOKENS=96
AIMLAPI_PROMPT_CHAR_LIMIT=2500
QUADRO_USE_AIMLAPI=0

# Optional Featherless AI partner lane.
# OpenAI-compatible API used only for verifier commentary after Quadro computes
# the decision packet.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_MAX_TOKENS=240
FEATHERLESS_PROMPT_CHAR_LIMIT=4000
FEATHERLESS_HTTP_REFERER=https://lablab.ai/ai-hackathons/band-of-agents-hackathon
FEATHERLESS_X_TITLE=Quadro CSI
FEATHERLESS_USER_AGENT=QuadroCSI/0.1 (+https://lablab.ai/ai-hackathons/band-of-agents-hackathon)
QUADRO_USE_FEATHERLESS=0

# Optional local Hermes model readout lane.
# This calls a local endpoint only; it does not spend AI/ML API credits.
QUADRO_USE_HERMES=0
QUADRO_HERMES_URL=http://127.0.0.1:8788
QUADRO_HERMES_MODEL=hermes
QUADRO_HERMES_AGENT_ROLES=evidence,policy,decision
QUADRO_HERMES_MAX_NEW_TOKENS=96
QUADRO_HERMES_PROMPT_CHAR_LIMIT=6000
QUADRO_HERMES_TIMEOUT=45
