        "query": "passconsent2026",
        "scope_tags": [
          "consent_record"
        ],
        "limit": 2
      },
      {
        "query": "passfinancial2026",
        "scope_tags": [
          "financial_terms"
        ],
        "limit": 2
      },
      {
        "query": "passapproval2026",
        "scope_tags": [
          "approval_policy"
        ],
        "limit": 2
      }
